{
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node \"${PLUGIN_ROOT}/scripts/auto-update.mjs\" hook session-start",
						"timeout": 5,
						"statusMessage": "(OmO) Checking Auto Update"
					}
				],
				"matcher": "^startup$"
			}
		]
	}
}
